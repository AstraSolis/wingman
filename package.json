{
  "name": "wingman",
  "version": "1.0.0",
  "description": "游戏攻略悬浮窗助手 - 为 PC 游戏玩家设计的置顶透明攻略窗口",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "node scripts/start.js",
    "dist": "npm run build && electron-builder",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"*.js\" \"preload.js\" \"main.js\"",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"*.js\" \"preload.js\" \"main.js\"",
    "check": "npm run format && npm run lint"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "vite": "^8.0.8",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.wingman.app",
    "productName": "Wingman",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wingman"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/main/**/*",
      "src/common/**/*",
      "src/locales/**/*",
      "src/assets/**/*",
      "dist/renderer/**/*"
    ]
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
